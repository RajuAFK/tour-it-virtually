# ─── Anthropic (AI chat feature) ────────────────────────────────────────────
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Supabase ────────────────────────────────────────────────────────────────
# Project: tour-it-virtually  |  https://supabase.com/dashboard/project/hhjevofbfbovcwzpahjo
NEXT_PUBLIC_SUPABASE_URL=https://hhjevofbfbovcwzpahjo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server-only, never expose to client

# ─── Cloudflare R2 (virtual tour files CDN) ──────────────────────────────────
# After uploading tour folders to your R2 bucket and enabling public access,
# set this to your R2 public URL (e.g. https://pub-xxxx.r2.dev or custom domain).
# Then replace REPLACE_WITH_R2_URL in data/locations.json with this value.
NEXT_PUBLIC_TOURS_BASE_URL=https://REPLACE_WITH_R2_PUBLIC_URL
